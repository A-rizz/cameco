# ============================================================
# APPLICATION
# ============================================================
APP_NAME=CAMECO
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ============================================================
# SECURITY / CRYPTO
# ============================================================
BCRYPT_ROUNDS=12

# ============================================================
# LOGGING (SIGNOZ OBSERVABILITY SETUP)
# ============================================================

# Use stderr so logs are captured by container runtime + OTEL collector
#LOG_CHANNEL=stderr for signoz

LOG_CHANNEL=stack #or daily whatever you like
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
#LOG_LEVEL=info for signoz 

# ============================================================
# DATABASE
# ============================================================
DB_CONNECTION=sqlite
#DB_HOST=127.0.0.1
#DB_PORT=5432
#DB_DATABASE=
#DB_USERNAME=
#DB_PASSWORD=

# ============================================================
# SESSION
# ============================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ============================================================
# CACHE / QUEUE / BROADCAST
# ============================================================
QUEUE_CONNECTION=database
CACHE_STORE=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ============================================================
# REDIS
# ============================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================================
# MAIL
# ============================================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.ethereal.email
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@cameco.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# AWS (PLACEHOLDER)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ============================================================
# FRONTEND
# ============================================================
VITE_APP_NAME="${APP_NAME}"

# ============================================================
# SUPPORT CONTRACT (TEMPLATE METADATA ONLY)
# ============================================================
SUPPORT_CONTRACT_NUMBER=CAMECO-2025-001
SUPPORT_START_DATE=2025-11-08
SUPPORT_END_DATE=2027-11-08
SUPPORT_LEVEL=premium
SUPPORT_CONTACT_EMAIL=support@example.com
SUPPORT_CONTACT_PHONE=+1-555-0100

# ============================================================
# FEATURE FLAGS / MODULE SYSTEM
# ============================================================
MODULE_EMPLOYEE_ENABLED=true
MODULE_LEAVE_ENABLED=false
MODULE_DOCUMENTS_ENABLED=false
MODULE_ATS_ENABLED=false
MODULE_WORKFORCE_ENABLED=false
MODULE_TIMEKEEPING_ENABLED=false
MODULE_APPRAISALS_ENABLED=false
MODULE_OFFBOARDING_ENABLED=false
MODULE_PAYROLL_ENABLED=false
MODULE_ADMIN_ENABLED=false
MODULE_SYSTEM_ENABLED=false
